{
  "display_information": {
    "name": "operation-agent",
    "description": "障害診断エージェント - システム障害の原因調査と復旧手順を提案します",
    "background_color": "#2c2d30"
  },
  "features": {
    "bot_user": {
      "display_name": "operation-agent",
      "always_online": false
    }
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "app_mentions:read",
        "chat:write",
        "channels:history",
        "groups:history"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "request_url": "https://<API_GATEWAY_URL>/slack/events",
      "bot_events": [
        "app_mention"
      ]
    },
    "interactivity": {
      "is_enabled": false
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": false,
    "token_rotation_enabled": false
  }
}
