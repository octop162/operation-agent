# AWS Configuration
AWS_REGION=ap-northeast-1
AWS_PROFILE=default

# Bedrock Model
DIAG_MODEL_ID=apac.anthropic.claude-sonnet-4-20250514-v1:0

# MySQL Lambda Tool
DIAG_MYSQL_LAMBDA_FUNCTION=

# Notion (optional)
NOTION_API_KEY=
NOTION_DATABASE_ID=

# Slack (optional)
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# OpenTelemetry (optional)
DIAG_OTEL_ENABLED=false
DIAG_OTEL_EXPORTER=console           # console | otlp
OTEL_SERVICE_NAME=operation-agent
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317  # otlp 時のみ
